{
  "name": "swz-quick-memos",
  "version": "0.2.0",
  "description": "Markdown-native Obsidian quick memo plugin",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "memo",
    "daily-notes"
  ],
  "author": "songwz",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.23.0",
    "obsidian": "latest",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0",
    "jsdom": "^24.1.0"
  }
}
